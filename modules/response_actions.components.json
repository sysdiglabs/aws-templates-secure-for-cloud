[
  {
    "type": "COMPONENT_CLOUD_RESPONDER",
    "instance": "secure-runtime",
    "cloudResponderMetadata": {
      "aws": {
        "crossAccountRoleName": "{{CrossAccountRoleName}}",
        "validationRoleName": "{{ValidationRoleName}}",
        "regions": [
          "{{Regions}}"
        ],
        "lambdaNames": [
          "{{QuarantineUserLambdaName}}",
          "{{FetchCloudLogsLambdaName}}",
          "{{RemovePolicyLambdaName}}",
          "{{ConfigureResourceAccessLambdaName}}",
          "{{CreateVolumeSnapshotsLambdaName}}",
          "{{DeleteVolumeSnapshotsLambdaName}}"
        ]
      }
    }
  },
  {
    "type": "COMPONENT_CLOUD_RESPONDER_ROLES",
    "instance": "secure-runtime",
    "cloudResponderRolesMetadata": {
      "validationRole": {
        "aws": {
          "roleName": "{{ValidationRoleName}}"
        }
      },
      "roles": [
        {
          "aws": {
            "roleName": "{{QuarantineUserRoleName}}"
          }
        },
        {
          "aws": {
            "roleName": "{{FetchCloudLogsRoleName}}"
          }
        },
        {
          "aws": {
            "roleName": "{{RemovePolicyRoleName}}"
          }
        },
        {
          "aws": {
            "roleName": "{{ConfigureResourceAccessRoleName}}"
          }
        },
        {
          "aws": {
            "roleName": "{{CreateVolumeSnapshotsRoleName}}"
          }
        },
        {
          "aws": {
            "roleName": "{{DeleteVolumeSnapshotsRoleName}}"
          }
        }
      ]
    }
  }
]
